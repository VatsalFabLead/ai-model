# Copy to .env and update values
APP_NAME=Custom Model API
APP_ENV=dev
# Generate with: python scripts/generate_key.py  (multiple keys: key1,key2,key3)
API_KEY=change-me-to-a-strong-key
HOST=127.0.0.1
PORT=8000
REQUEST_TIMEOUT_SECONDS=120

# Backend: custom (from-scratch NumPy) | llm (free open-source GGUF) | ollama
MODEL_BACKEND=custom

# Free open-source local model (GGUF via llama.cpp). Not GPT/Claude/Gemini.
LLM_MODEL_PATH=models/llm/qwen2.5-0.5b-instruct-q4_k_m.gguf
LLM_CONTEXT=4096
LLM_THREADS=4
LLM_MAX_TOKENS=1024
LLM_TEMPERATURE=0.7
USE_RAG=true

# Custom model — 100% your own weights (no third-party models)
MODEL_ID=custom-nexus-v1
MODEL_WEIGHTS_PATH=models/weights/nexus_v1.npz
TOKENIZER_PATH=models/tokenizer/vocab.json

# Architecture — Hostinger VPS friendly (increase on powerful local machine)
D_MODEL=256
N_HEADS=4
N_LAYERS=4
D_FF=1024
MAX_SEQ_LEN=256
VOCAB_SIZE=4096

# Inference defaults
MAX_NEW_TOKENS=512
TEMPERATURE=0.7
TOP_K=40
TOP_P=0.9
USE_NEURAL_FALLBACK=true
INFERENCE_MAX_PASSES=4
CHAT_COMPLETION_MAX_PASSES=4
# Answer length: 0 = no min/max word limit (natural length)
ANSWER_MIN_WORDS=0
ANSWER_MAX_WORDS=0

# Security
CORS_ORIGINS=*
# Rate limit: set RATE_LIMIT_ENABLED=false for none, or cap per-IP requests.
RATE_LIMIT_ENABLED=true
RATE_LIMIT=300/minute
TRUSTED_HOSTS=*

# Merge into parent server
API_PREFIX=/v1
ROOT_PATH=
